# ─────────────────────────────────────────────────────
# MicroBounty — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────

# Supabase (Frontend — exposed to browser)
VITE_SUPABASE_URL=https://sditsitcwpjsxbxnzqtf.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (Backend only — NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Algorand
VITE_APP_ID=your-algorand-app-id
VITE_NETWORK=testnet

# Algorand Node (already in your existing .env)
VITE_ALGOD_TOKEN=
VITE_ALGOD_SERVER=https://testnet-api.4160.nodely.dev
VITE_ALGOD_PORT=443
VITE_ALGOD_NETWORK=testnet

# Indexer
VITE_INDEXER_TOKEN=
VITE_INDEXER_SERVER=https://testnet-idx.4160.nodely.dev
VITE_INDEXER_PORT=443
